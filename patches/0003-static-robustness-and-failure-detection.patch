diff --git a/vins/src/factor/zero_motion_factor.h b/vins/src/factor/zero_motion_factor.h
new file mode 100644
index 0000000..215f223
--- /dev/null
+++ b/vins/src/factor/zero_motion_factor.h
@@ -0,0 +1,65 @@
+/*******************************************************
+ * 零运动约束 —— 本项目新增，非上游文件
+ *
+ * 静止时约束窗口内相邻两帧的位移为零: residual = P_j - P_i
+ *
+ * 为什么不能用「冻结位姿」代替(实测走过的弯路):
+ *   processIMU() 在优化【之前】就用 IMU 死递推推进了新帧的位姿:
+ *       Ps[j] += dt * Vs[j] + 0.5 * dt * dt * un_acc;
+ *   这是给优化器的初值。如果这时把位姿 SetParameterBlockConstant，
+ *   等于把这个带着零偏误差的递推结果【锁死】，优化器再也没机会纠正它。
+ *   实测: 速度精确为 0、零偏也正常，位置照样 4 分钟漂 2.23 米。
+ *   冻结不是「锁住不动」，是「锁住错误」。
+ *
+ * 为什么也不能只靠零速约束:
+ *   IMU 位置残差里的 delta_p 由加速度计零偏决定，零偏一错，
+ *   每个窗口步长都会给位置加一个固定增量。而零偏在静止时不可观，
+ *   还会被边缘化先验锁死在错误值上(实测反复冻结在 0.68 / 0.21)。
+ *   实测只冻速度: 位置仍从 1.2cm 漂到 1.22m(8 分钟)。
+ *
+ * 这里用【相对】约束而不是绝对约束，有两个好处:
+ *   1) 不与边缘化先验争夺绝对位置，避免早前软约束被先验压过的问题
+ *   2) 优化器仍可自由调整整体位姿去满足视觉观测，只是不许窗口内部产生位移
+ *******************************************************/
+
+#pragma once
+
+#include <ceres/ceres.h>
+#include <eigen3/Eigen/Dense>
+
+// 参数块是两个 para_Pose，布局为 [P(0..2), Q(3..6)]，这里只约束平移部分。
+class ZeroMotionFactor : public ceres::SizedCostFunction<3, 7, 7>
+{
+  public:
+    // sigma 取 2mm: 远小于需要抑制的漂移量(实测每帧约 0.5mm、每分钟数百 mm)，
+    // 又不是硬约束，视觉观测仍能让整体位姿平滑调整。
+    static constexpr double SIGMA = 0.002;
+
+    virtual bool Evaluate(double const *const *parameters, double *residuals,
+                          double **jacobians) const
+    {
+        const double w = 1.0 / SIGMA;
+        for (int k = 0; k < 3; ++k)
+            residuals[k] = w * (parameters[1][k] - parameters[0][k]);
+
+        // 注意 jacobian 的列数是 7(参数块的 ambient size)，
+        // 但 PoseLocalParameterization 的切空间是 6 维，
+        // ceres 会用 manifold 的 PlusJacobian 自动做投影，这里按 ambient 写即可。
+        if (jacobians)
+        {
+            if (jacobians[0])
+            {
+                Eigen::Map<Eigen::Matrix<double, 3, 7, Eigen::RowMajor>> J(jacobians[0]);
+                J.setZero();
+                J.block<3, 3>(0, 0) = -w * Eigen::Matrix3d::Identity();
+            }
+            if (jacobians[1])
+            {
+                Eigen::Map<Eigen::Matrix<double, 3, 7, Eigen::RowMajor>> J(jacobians[1]);
+                J.setZero();
+                J.block<3, 3>(0, 0) = w * Eigen::Matrix3d::Identity();
+            }
+        }
+        return true;
+    }
+};

+            printf("  PROBDBG 残差块=%d 参数块=%d | IMU因子 加%d 跳%d sum_dt[%.2f,%.2f] "
+                   "| 视觉观测=%d frame_count=%d\n",
+                   problem.NumResidualBlocks(), problem.NumParameterBlocks(),
+                   _imu_add, _imu_skip, _min_dt, _max_dt, f_m_cnt, frame_count);
+    }
     TicToc t_solver;
     ceres::Solver::Summary summary;
     ceres::Solve(options, &problem, &summary);
+
+    // 本地诊断: 优化器一旦不再更新状态，位置就会失控发散。实测多个版本里
+    // Ba 都会在某一刻突然「一字不差地冻住」，随后位置在 2 分钟内从 0.3m
+    // 涨到 2m。这里把 Ceres 自己的终止原因打出来，才能知道它到底是
+    // 收敛了、还是因为代价非有限/线性求解失败之类的原因直接放弃了。
+    if (summary.termination_type != ceres::CONVERGENCE)
+    {
+        ROS_WARN("Ceres 未收敛: %s | 迭代 %d | 代价 %.6e -> %.6e",
+                 summary.message.c_str(),
+                 static_cast<int>(summary.iterations.size()),
+                 summary.initial_cost, summary.final_cost);
+    }
     //cout << summary.BriefReport() << endl;
     ROS_DEBUG("Iterations : %d", static_cast<int>(summary.iterations.size()));
     //printf("solver costs: %f \n", t_solver.toc());

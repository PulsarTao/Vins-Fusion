+// ---------------------------------------------------------------------------
+// 零速修正(ZUPT)的静止检测 —— 本项目新增
+//
+// 判据用【标准差】而不是原始读数:
+//   * 陀螺静止时读数不为零(它就是零偏，本机实测 0.028 rad/s)，
+//     直接对模长设阈值会把静止误判成运动
+//   * 加速度计静止时读数是重力(约 9.9)，同理不能对模长设阈值
+// 所以看的是「读数波动有多小」。本机实测静止时的标准差:
+//     accel 0.006 m/s²   gyro 0.0006 rad/s
+// 阈值取实测值的约 10 倍，留足余量。
+//
+// 另加一条重力模长校验: 匀加速运动时标准差同样很小，但比力模长会偏离 g，
+// 单看标准差会漏判。
+//
+// 迟滞: 连续 5 个图像区间(约 0.5s)判定为静止才进入静止态，
+// 一旦有一个区间判定为运动就立刻退出 —— 宁可少修正，不可误修正。
+bool Estimator::detectStatic(const vector<pair<double, Eigen::Vector3d>> &accVector,
+                             const vector<pair<double, Eigen::Vector3d>> &gyrVector)
+{
+    const double ACC_STD_TH = 0.06;      // m/s²
+    const double GYR_STD_TH = 0.008;     // rad/s
+    const double G_DEV_TH   = 0.5;       // m/s²，比力模长偏离重力的容许量
+    const int    HOLD_N     = 5;         // 迟滞: 需连续多少个区间
+
+    bool moving = true;
+    if (accVector.size() >= 5 && gyrVector.size() == accVector.size())
+    {
+        Eigen::Vector3d am = Eigen::Vector3d::Zero(), gm = Eigen::Vector3d::Zero();
+        for (size_t i = 0; i < accVector.size(); i++)
+        {
+            am += accVector[i].second;
+            gm += gyrVector[i].second;
+        }
+        am /= accVector.size();
+        gm /= gyrVector.size();
+
+        Eigen::Vector3d av = Eigen::Vector3d::Zero(), gv = Eigen::Vector3d::Zero();
+        for (size_t i = 0; i < accVector.size(); i++)
+        {
+            av += (accVector[i].second - am).cwiseAbs2();
+            gv += (gyrVector[i].second - gm).cwiseAbs2();
+        }
+        const double a_std = std::sqrt((av / accVector.size()).maxCoeff());
+        const double g_std = std::sqrt((gv / gyrVector.size()).maxCoeff());
+
+        moving = (a_std > ACC_STD_TH) || (g_std > GYR_STD_TH) ||
+                 (std::fabs(am.norm() - G.norm()) > G_DEV_TH);
+    }
+
+    if (moving)
+    {
+        static_count = 0;
+        if (is_static)
+            ROS_INFO("ZUPT: 检测到运动，退出零速修正");
+        is_static = false;
+    }
+    else
+    {
+        static_count++;
+        if (!is_static && static_count >= HOLD_N)
+        {
+            is_static = true;
+            ROS_INFO("ZUPT: 检测到静止，启用零速修正");
+        }
+    }
+    return is_static;
+}

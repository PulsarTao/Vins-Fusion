+/*******************************************************
+ * 零速修正(ZUPT) —— 本项目新增，非上游文件
+ *
+ * 为什么需要它:
+ *   加速度计零偏与重力方向在【无运动】时高度耦合、几乎不可观 ——
+ *   要靠姿态变化才能把两者解耦。VINS-Fusion 没有零速修正，
+ *   相机长时间静止时零偏就一路随机游走。本机实测(seeker1 四目鱼眼，
+ *   相机静置桌面 47 分钟)，Ba_y 的演化:
+ *       0.002 -> 0.18 -> 0.49 -> 0.60 -> 0.72 m/s²
+ *   而静止实测加速度是 (0.234, 0.098, 9.884)，真实零偏应该很小，
+ *   0.68 m/s² 在物理上不合理。零偏走到病态区域后优化退化、状态冻结，
+ *   位置随即按 0.5*Ba*t² 二次爆炸(实测漂到 6876 米)。
+ *
+ * 做法:
+ *   检测到静止时，给窗口内每一帧的速度加一个「速度应为零」的残差。
+ *   速度被钉住后，IMU 预积分的速度残差
+ *       r_v = delta_v(Ba,Bg) - R_i^T * g * dt
+ *   就直接决定了 Ba —— 零偏从「不可观、随便游走」变成「有唯一解」，
+ *   连带把零偏也稳住了，不需要另外再加零偏保持项。
+ *
+ * 对运动工况无影响: 静止检测不通过时这个因子根本不会被加进 problem。
+ *******************************************************/
+
+#pragma once
+
+#include <ceres/ceres.h>
+#include <eigen3/Eigen/Dense>
+
+#include "../estimator/parameters.h"
+
+// 参数块是 para_SpeedBias[i]，布局为 [V(0..2), Ba(3..5), Bg(6..8)]，
+// 这里只对前三维(速度)施加约束。
+class ZeroVelocityFactor : public ceres::SizedCostFunction<3, 9>
+{
+  public:
+    // sigma 取 1mm/s: 比 IMU 因子的速度不确定度(acc_n=0.1 时约 32mm/s)强一个量级，
+    // 足以钉住速度；又不是硬约束，姿态/零偏仍有调整余地，退出静止时能平滑过渡。
+    static constexpr double SIGMA = 0.001;
+
+    virtual bool Evaluate(double const *const *parameters, double *residuals,
+                          double **jacobians) const
+    {
+        const double w = 1.0 / SIGMA;
+
+        residuals[0] = w * parameters[0][0];
+        residuals[1] = w * parameters[0][1];
+        residuals[2] = w * parameters[0][2];
+
+        if (jacobians && jacobians[0])
+        {
+            Eigen::Map<Eigen::Matrix<double, 3, 9, Eigen::RowMajor>> J(jacobians[0]);
+            J.setZero();
+            J.block<3, 3>(0, 0) = w * Eigen::Matrix3d::Identity();
+        }
+        return true;
+    }
+};

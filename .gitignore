# ---------------------------------------------------------------------------
# 第三方 VINS-Fusion ROS2 源码
# 不纳入版本控制：它是上游 GPL-3.0 项目，有明确的仓库和版本号，
# 且含一个 58MB 的词袋二进制文件(brief_k10L6.bin)。
# 用 ./scripts/fetch_upstream.sh 自动获取指定版本，详见 docs/UPSTREAM.md
# ---------------------------------------------------------------------------
src_upstream/

# 构建中间产物（由 scripts/build_*.sh 自动生成）
build_ctx/
dist/

# seeker 驱动的 colcon 工作区（由 run.sh local seeker 自动创建）
# src/seeker1 是指向 ros2_ws_src/seeker1 的软链，源码本体已在版本控制里
.seeker_ws/

# IMU 标定工作区与中间产物
# .calib_ws 是 allan_variance_ros 的 clone（上游仓库，同 src_upstream 的理由）；
# 曲线图和 imu.yaml 是 analysis.py 的输出，标定结论已固化进
# scripts/gen_seeker_config.py 的噪声参数，无需入库。
.calib_ws/
allan_deviation.csv
acceleration.png
gyro.png
imu.yaml

# 回放专用配置（由 scripts/make_replay_config.sh 生成）
config/seeker/_rp.yaml

# 运行时输出
*.log
output/
logs/

# 系统垃圾文件
.DS_Store
Thumbs.db
*~
*.swp
*.bak
*.tmp

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# IDE
.vscode/
.idea/
*.iml
